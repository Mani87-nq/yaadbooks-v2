{
  "name": "yaadbooks-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:smoke": "playwright test smoke.spec.ts",
    "test:e2e:security": "playwright test security.spec.ts",
    "test:e2e:accessibility": "playwright test accessibility.spec.ts",
    "test:e2e:visual": "playwright test visual.spec.ts",
    "test:e2e:api": "playwright test api.spec.ts",
    "test:e2e:report": "playwright show-report",
    "test:e2e:update-snapshots": "playwright test visual.spec.ts --update-snapshots",
    "test:load": "k6 run tests/load/load-test.js",
    "test:load:smoke": "k6 run --vus 1 --duration 30s tests/load/load-test.js",
    "test:all": "npm run test:e2e:smoke && npm run test:e2e:security && npm run test:e2e:api",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@heroicons/react": "^2.2.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@sentry/nextjs": "^10.43.0",
    "@tanstack/react-query": "^5.90.21",
    "@types/dompurify": "^3.2.0",
    "argon2": "^0.44.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "decimal.js": "^10.6.0",
    "dompurify": "^3.3.3",
    "jose": "^6.2.1",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "otpauth": "^9.5.0",
    "pg": "^8.20.0",
    "posthog-js": "^1.360.2",
    "prisma": "^7.5.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "^1.52.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
